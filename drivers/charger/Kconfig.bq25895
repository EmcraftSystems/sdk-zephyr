config CHARGER_BQ25895
	bool "BQ25895 Battery Charger"
	default y
	depends on DT_HAS_TI_BQ25895_ENABLED
	select I2C
	help
	  Enable BQ25895 battery charger driver.

module = BQ25895
module-str = bq25895

source "subsys/logging/Kconfig.template.log_config"
